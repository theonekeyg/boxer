# Algolia DocSearch credentials
# Copy this file to .env.local and fill in the values.
# See docs/README.md for setup instructions.

ALGOLIA_APP_ID=
ALGOLIA_SEARCH_API_KEY=
ALGOLIA_INDEX_NAME=boxer

# ALGOLIA_WRITE_API_KEY is used by the docsearch-scraper (CI and local `pnpm index`).
# Never expose this in the browser — it has write access to your index.
ALGOLIA_WRITE_API_KEY=
